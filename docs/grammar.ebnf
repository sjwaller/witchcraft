(* Witchcraft v0.1 grammar (EBNF). Kept in step with crates/witchcraft/src/parser.rs.
   Mundane host syntax is un-themed; occult vocabulary names the genuinely new. *)

program        = { item } ;
item           = fn_decl | type_decl | familiar_decl | statement ;

fn_decl        = "define" ident "(" [ param { "," param } ] ")" [ ":" type ]
                 [ "requires" capability { "," capability } ] block ;
param          = ident [ ":" type ] ;

(* A capability identity: a kind plus an optional parameter, e.g.
   permit(escalate), scope(tenant). Compile-time only; erased before lowering. *)
capability     = ident [ "(" ident ")" ] ;

type_decl      = "type" ident "=" type ;
type           = record_type | sum_type | list_type | refined | named ;
list_type      = "list" "of" [ bound "of" ] type ;
bound          = number ".." number ;
record_type    = "{" [ field { "," field } ] "}" ;
field          = ident ":" type ;
sum_type       = "one_of" "{" [ variant { "," variant } ] "}" ;
variant        = ident [ "(" [ field { "," field } ] ")" ] ;
refined        = ident "in" number ".." number ;       (* only `spark` may be refined *)
named          = ident ;                                (* spark | glyph | bool | oracle | user type *)

block          = "{" { statement } "}" ;

statement      = let_stmt | var_stmt | assign | speak_stmt
               | while_stmt | if_stmt | return_stmt
               | summon_stmt | divine_stmt | enact_stmt | grant_stmt
               | memory_decl | within_stmt | expr ;

let_stmt       = "let" ident [ ":" type ] "=" expr ;
var_stmt       = "var" ident [ ":" type ] "=" expr ;
assign         = ident "=" expr ;
speak_stmt     = "speak" expr ;
while_stmt     = "while" expr block ;
if_stmt        = "if" expr block [ "else" block ] ;
return_stmt    = "return" [ expr ] ;

summon_stmt    = "oracle" ident "=" "summon" glyph_literal ;

(* The discharge clause is grammar-OPTIONAL; the type system enforces discharge. *)
divine_stmt    = "divine" ident ":" type
                 "from" "(" [ expr { "," expr } ] ")"
                 "using" ident
                 [ "with" "confidence" ">=" number "fallback" expr ] ;

enact_stmt     = "enact" expr "{" { enact_arm } "}" ;
enact_arm      = ident [ "(" [ ident { "," ident } ] ")" ] "=>" block [ "," ] ;

(* Grants its capabilities to the enclosed region. Compile-time only. *)
grant_stmt     = "with" "grant" capability { "," capability } block ;

(* Governed memory: scope is a capability; `within` grants scope(<name>). *)
memory_decl    = "memory" ident "{" { mem_setting [ "," ] } "}" ;
mem_setting    = "scope" ident
               | "retention" number [ ident ]
               | "retrieval" ident { "+" ident }
               | "audit" ident ;
within_stmt    = "within" ident block ;
(* memory access is postfix: mem.write(v) | mem.recent(k) *)

(* Bounded composite; `permits` is the checkable capability boundary. *)
familiar_decl  = "familiar" ident "(" [ param { "," param } ] ")"
                 "permits" "{" [ permit { "," permit } ] "}" block ;
permit         = ident [ ident ] ;        (* e.g. `escalate`, `invoke triage` *)

(* Expressions, lowest to highest precedence. *)
expr           = or_expr ;
or_expr        = and_expr { "or" and_expr } ;
and_expr       = cmp_expr { "and" cmp_expr } ;
cmp_expr       = add_expr { ( "<" | "<=" | ">" | ">=" | "==" | "!=" ) add_expr } ;
add_expr       = mul_expr { ( "+" | "-" ) mul_expr } ;
mul_expr       = unary { ( "*" | "/" ) unary } ;
unary          = ( "not" | "-" ) unary | postfix ;
postfix        = primary { "." ident [ "(" [ expr { "," expr } ] ")" ] } ;
primary        = number | "true" | "false" | glyph_literal
               | "listen" "(" expr ")"
               | "(" expr ")"
               | record_literal
               | list
               | ident [ "(" [ expr { "," expr } ] ")" ]    (* call / builtin (similarity, nearest, listen) *)
               | Ident [ "(" [ field_init { "," field_init } ] ")" ] ; (* variant ctor *)
record_literal = "{" [ field_init { "," field_init } ] "}" ;
field_init     = ident [ ":" expr ] ;
list           = "[" [ expr { "," expr } ] "]" ;       (* homogeneous list literal *)
(* postfix `.embed(...)` on an oracle yields a space-tagged embedding *)

glyph_literal  = '"' { glyph_char | "${" expr "}" } '"' ;  (* ${...} interpolation *)
number         = digit { digit } [ "." digit { digit } ] ;
ident          = ( letter | "_" ) { letter | digit | "_" } ;
