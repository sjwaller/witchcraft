# Mundane host language: plain keywords, no occult vocabulary needed here (§7).

define add(a, b) {
    a + b
}

let name = "witch"
speak "Greetings, ${name}!"

var n = 0
while n < 3 {
    speak "n = ${n}"
    n = n + 1
}

if add(2, 3) == 5 {
    speak "arithmetic holds"
} else {
    speak "the universe is broken"
}
